generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  PARTICIPANT
}


model User {
  id                 Int       @id @default(autoincrement())
  registrationNumber String    @unique
  name               String
  role               Role      @default(PARTICIPANT)
  otp                String?
  otpExpired         DateTime?
  createdAt          DateTime  @default(now())
  attempts           Attempt[]
}

model TestType {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  tests     Test[]
  createdAt DateTime  @default(now())
}


model Test {
  id            Int              @id @default(autoincrement())
  title         String
  description   String?
typeId        Int?
type          TestType?   @relation(fields: [typeId], references: [id])

  questions     Question[]
  attempts      Attempt[]
  createdAt     DateTime         @default(now())
}


model Question {
  id           Int      @id @default(autoincrement())
  text         String
  options      Json
  answer       String?
  questionType String @default("MULTIPLE_CHOICE")
  autoScore    Int?
  testId       Int
  test         Test       @relation(fields: [testId], references: [id])
}
model Attempt {
  id           Int      @id @default(autoincrement())
  userId       Int
  testId       Int
  answers      Json
  autoScore    Int?
  manualScore  Int?
  finalScore   Int?
  passStatus   String?
  completedAt  DateTime @default(now())
  gradedAt     DateTime?

  user User @relation(fields: [userId], references: [id])
  test Test @relation(fields: [testId], references: [id])

  @@unique([userId, testId])
}



model Mahasiswa {
  id        Int      @id @default(autoincrement())
  nama      String
  nim       String   @unique
  provinsi String
  angkatan Int
  jalur_masuk String
  status String //aktif, cuti, lulus
  jenjang String
  gender String
  asal_sekolah String
  ipk Float

  fakultas_id Int
  fakultas fakultas @relation(fields: [fakultas_id], references: [id])

  prodi_id Int
  prodi prodi @relation(fields: [prodi_id], references: [id])
  
  kategoriDisabilitas MahasiswaKategoriDisabilitas[]
  
  // banyak jenis → pivot
  jenisDisabilitas MahasiswaJenisDisabilitas[]

  @@map("mahasiswa")
}

model fakultas {
  id       Int      @id @default(autoincrement())
  nama     String
  prodi prodi[]
  Mahasiswa Mahasiswa[]

  @@map("fakultas")
}

model prodi {
  id       Int      @id @default(autoincrement())
  nama     String
  fakultas_id Int
  fakultas fakultas @relation(fields: [fakultas_id], references: [id])
  Mahasiswa Mahasiswa[]
  @@map("prodi")
}

model jenisDisabilitas { //fisik,sensorik, mental
  id       Int      @id @default(autoincrement())
  jenis    String

  kategoriDisabilitas kategoriDisabilitas[]
  MahasiswaJenisDisabilitas MahasiswaJenisDisabilitas[]

  @@map("jenis_disabilitas")
}

model kategoriDisabilitas { //tuna daksa, netra, rungu rungu
  id       Int      @id @default(autoincrement())
  kategori String
  jenis_disabilitas_id Int?

  jenisDisabilitas jenisDisabilitas? @relation(fields: [jenis_disabilitas_id], references: [id])
  Mahasiswa MahasiswaKategoriDisabilitas[]

  @@map("kategori_disabilitas")
}

model MahasiswaJenisDisabilitas {
  id             Int         @id @default(autoincrement())
  mahasiswa_id   Int
  jenis_id       Int

  mahasiswa      Mahasiswa    @relation(fields: [mahasiswa_id], references: [id])
  jenis          jenisDisabilitas @relation(fields: [jenis_id], references: [id])

  @@map("mahasiswa_jenis_disabilitas")
}

model MahasiswaKategoriDisabilitas {
  id             Int         @id @default(autoincrement())
  mahasiswa_id   Int
  kategori_id    Int

  mahasiswa      Mahasiswa    @relation(fields: [mahasiswa_id], references: [id])
  kategori       kategoriDisabilitas @relation(fields: [kategori_id], references: [id])

  @@map("mahasiswa_kategori_disabilitas")
}

model Berita {
  id       Int      @id @default(autoincrement())
  title     String
  content_images String @default("")
  content   String @db.Text
  // tanggal acara/publikasi (opsional)
  tanggal   DateTime?
  lokasi    String?
  categoryId Int?
  category  BeritaCategory? @relation(fields: [categoryId], references: [id])
  isPublished Boolean @default(false)
  createdAt DateTime @default(now())

  @@map("berita")
}

model BeritaCategory {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())

  berita    Berita[]

  @@map("berita_category")
}