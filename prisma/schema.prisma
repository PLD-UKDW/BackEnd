generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  PARTICIPANT
}

enum TestType {
  DIGITAL_LITERACY
  COLLEGE_READINESS
}

model User {
  id                 Int       @id @default(autoincrement())
  registrationNumber String    @unique
  name               String
  role               Role      @default(PARTICIPANT)
  otp                String?
  otpExpired         DateTime?
  createdAt          DateTime  @default(now())
  attempts           Attempt[]
}

model Test {
  id          Int        @id @default(autoincrement())
  title       String
  type        TestType
  description String?
  questions   Question[]
  attempts    Attempt[]  // <── relasi balik ke Attempt
  createdAt   DateTime   @default(now())
}

model Question {
  id        Int      @id @default(autoincrement())
  text      String
  options   Json     // array pilihan (stored as JSON)
  answer    String?   // jawaban benar (tidak dikirim ke frontend)
  questionType String @default("MULTIPLE_CHOICE")
  testId    Int
  test      Test       @relation(fields: [testId], references: [id])
}

model Attempt {
  id            Int      @id @default(autoincrement())
  userId        Int
  testId        Int
  startedAt     DateTime @default(now())
  completedAt   DateTime?
  score         Int?
  answers       Json     // { "questionId": "selected option" }
  user          User     @relation(fields: [userId], references: [id])
  test          Test     @relation(fields: [testId], references: [id])
  @@unique([userId, testId]) // 1 attempt per user per test
}


model Mahasiswa {
  id        Int      @id @default(autoincrement())
  nama      String
  nim       String   @unique
  provinsi String
  angkatan Int
  jalur_masuk String
  status String //aktif, cuti, lulus
  jenjang String
  gender String
  asal_sekolah String
  ipk Float

  fakultas_id Int
  fakultas fakultas @relation(fields: [fakultas_id], references: [id])

  prodi_id Int
  prodi prodi @relation(fields: [prodi_id], references: [id])
  
  kategoriDisabilitas MahasiswaKategoriDisabilitas[]
  
  // banyak jenis → pivot
  jenisDisabilitas MahasiswaJenisDisabilitas[]

  @@map("mahasiswa")
}

model fakultas {
  id       Int      @id @default(autoincrement())
  nama     String
  prodi prodi[]
  Mahasiswa Mahasiswa[]

  @@map("fakultas")
}

model prodi {
  id       Int      @id @default(autoincrement())
  nama     String
  fakultas_id Int
  fakultas fakultas @relation(fields: [fakultas_id], references: [id])
  Mahasiswa Mahasiswa[]
  @@map("prodi")
}

model jenisDisabilitas { //fisik,sensorik, mental
  id       Int      @id @default(autoincrement())
  jenis    String

  kategoriDisabilitas kategoriDisabilitas[]
  MahasiswaJenisDisabilitas MahasiswaJenisDisabilitas[]

  @@map("jenis_disabilitas")
}

model kategoriDisabilitas { //tuna daksa, netra, rungu rungu
  id       Int      @id @default(autoincrement())
  kategori String
  jenis_disabilitas_id Int?

  jenisDisabilitas jenisDisabilitas? @relation(fields: [jenis_disabilitas_id], references: [id])
  Mahasiswa MahasiswaKategoriDisabilitas[]

  @@map("kategori_disabilitas")
}

model MahasiswaJenisDisabilitas {
  id             Int         @id @default(autoincrement())
  mahasiswa_id   Int
  jenis_id       Int

  mahasiswa      Mahasiswa    @relation(fields: [mahasiswa_id], references: [id])
  jenis          jenisDisabilitas @relation(fields: [jenis_id], references: [id])

  @@map("mahasiswa_jenis_disabilitas")
}

model MahasiswaKategoriDisabilitas {
  id             Int         @id @default(autoincrement())
  mahasiswa_id   Int
  kategori_id    Int

  mahasiswa      Mahasiswa    @relation(fields: [mahasiswa_id], references: [id])
  kategori       kategoriDisabilitas @relation(fields: [kategori_id], references: [id])

  @@map("mahasiswa_kategori_disabilitas")
}

model Berita {
  id       Int      @id @default(autoincrement())
  title     String
  content_images String
  content   String
  category  String
  isPublished Boolean @default(false)
  createdAt DateTime @default(now())

  @@map("berita")
}